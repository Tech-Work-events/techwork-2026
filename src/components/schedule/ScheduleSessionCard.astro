---
import type { Category, Speaker, Track } from '../../type'

interface Props {
    id: string
    title: string
    dateStart?: string | null
    dateEnd?: string | null
    durationMinutes?: number
    track?: Track
    category?: Category
    speakers: Speaker[]
    level?: string | null
    index?: number
}

const { id, title, dateStart, dateEnd, durationMinutes, track, category, speakers, level, index = 0 } = Astro.props

const levelLabels: Record<string, { label: string; color: string }> = {
    BEGINNER: { label: 'Débutant', color: 'bg-green-100 text-green-700' },
    INTERMEDIATE: { label: 'Intermédiaire', color: 'bg-yellow-100 text-yellow-700' },
    ADVANCED: { label: 'Avancé', color: 'bg-red-100 text-red-700' },
}

const levelInfo = level ? levelLabels[level] || { label: level, color: 'bg-gray-100 text-gray-700' } : null
---

<article
    class="card hover-lift scroll-animate-scale h-full flex flex-col"
    data-track={track?.id}
    data-category={category?.id}
    style={`animation-delay: ${index * 0.06}s`}>
    <!-- Header: Time + Track -->
    <div class="px-6 pt-5 pb-4 flex items-center justify-between border-b border-gray-100">
        <div class="flex items-center gap-3">
            <div
                class="w-10 h-10 bg-primary-100 text-primary-600 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>
            <div>
                {
                    dateStart && (
                        <div class="text-sm font-semibold text-gray-900">
                            {new Date(dateStart).toLocaleTimeString('fr', { hour: '2-digit', minute: '2-digit' })}
                            {dateEnd && (
                                <span class="text-gray-400">
                                    {' '}
                                    —{' '}
                                    {new Date(dateEnd).toLocaleTimeString('fr', { hour: '2-digit', minute: '2-digit' })}
                                </span>
                            )}
                        </div>
                    )
                }
                <div class="text-xs text-gray-500">{durationMinutes} min</div>
            </div>
        </div>
        {
            track && (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                    📍 {track.name}
                </span>
            )
        }
    </div>

    <!-- Body -->
    <div class="px-6 py-5 flex-1 flex flex-col gap-3">
        <!-- Title -->
        <h3 class="text-lg font-bold text-gray-900 leading-snug">
            <a href={`/sessions/${id}`} class="hover:text-primary-600 transition-colors duration-200">
                {title}
            </a>
        </h3>

        <!-- Badges -->
        <div class="flex flex-wrap gap-2">
            {
                category && (
                    <span
                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium"
                        style={
                            category.color
                                ? `background-color: ${category.colorSecondary || category.color + '20'}; color: ${category.color}`
                                : ''
                        }>
                        {category.name}
                    </span>
                )
            }
            {
                levelInfo && (
                    <span
                        class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${levelInfo.color}`}>
                        {levelInfo.label}
                    </span>
                )
            }
        </div>

        <!-- Speakers -->
        {
            speakers && speakers.length > 0 && (
                <div class="mt-auto pt-3">
                    <div class="flex flex-col gap-2">
                        {speakers.map((speaker) => (
                            <a href={`/speakers/${speaker.id}`} class="flex items-center gap-3 group">
                                {speaker.photoUrl ? (
                                    <img
                                        class="w-8 h-8 rounded-full object-cover flex-shrink-0 group-hover:scale-110 transition-transform duration-200"
                                        src={speaker.photoUrl}
                                        alt={speaker.name}
                                        width="32"
                                        height="32"
                                        loading="lazy"
                                        decoding="async"
                                        onerror="this.onerror=null;this.src='/favicon-96x96.png'"
                                    />
                                ) : (
                                    <img
                                        class="w-8 h-8 rounded-full object-cover flex-shrink-0 group-hover:scale-110 transition-transform duration-200"
                                        src="/favicon-96x96.png"
                                        alt={speaker.name}
                                        width="32"
                                        height="32"
                                        loading="lazy"
                                        decoding="async"
                                    />
                                )}
                                <div class="min-w-0">
                                    <div class="text-sm font-medium text-gray-900 group-hover:text-primary-600 transition-colors duration-200 truncate">
                                        {speaker.name}
                                    </div>
                                    {speaker.company && (
                                        <div class="text-xs text-gray-500 truncate">{speaker.company}</div>
                                    )}
                                </div>
                            </a>
                        ))}
                    </div>
                </div>
            )
        }
    </div>

    <!-- Footer: CTA -->
    <div class="px-6 py-4 border-t border-gray-100 bg-gray-50/50">
        <a
            href={`/sessions/${id}`}
            class="btn btn-primary w-full text-sm py-2.5 group"
            aria-label={`Voir le détail de la session ${title}`}>
            <span class="mr-2 group-hover:animate-bounce-gentle" aria-hidden="true">📋</span>
            Voir le détail
        </a>
    </div>
</article>

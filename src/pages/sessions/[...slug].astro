---
import { Markdown } from '@astropub/md'
import { markdownToTxt } from 'markdown-to-txt'
import Layout from '../../layouts/Layout.astro'
import MarkdownWrapper from '../../components/ui-elements/MarkdownWrapper.astro'
import { getScheduleData } from '../../data/conference-hall'

export async function getStaticPaths() {
    const { sessions, speakers, categories, tracks } = getScheduleData()

    const uniqueDays = sessions.reduce((acc, session) => {
        if (session.dateStart && session.trackId) {
            const date = new Date(session.dateStart)
            date.setHours(0, 0, 0, 0)
            const timestamp = date.getTime()
            if (!acc.has(timestamp)) {
                acc.add(timestamp)
            }
        }
        return acc
    }, new Set<number>())
    const sortedDays = Array.from(uniqueDays.values()).sort()

    return sessions.map((session) => {
        const date = session.dateStart ? new Date(session.dateStart) : new Date()
        date.setHours(0, 0, 0, 0)
        const timestamp = date.getTime()

        return {
            params: { slug: session.id },
            props: {
                ...session,
                parentUrl: `/schedule/day-${sortedDays.indexOf(timestamp) + 1}`,
                speakers: speakers.filter((speaker) => session.speakerIds.includes(speaker.id)),
                category: categories.find((cat) => cat.id === session.categoryId),
                track: tracks.find((track) => track.id === session.trackId),
            },
        }
    })
}

const {
    title,
    track,
    abstract,
    category,
    level,
    speakers,
    dateStart,
    dateEnd,
    durationMinutes,
    parentUrl,
    teaserImageUrl,
    hideTrackTitle,
} = Astro.props

const rawAbstract = abstract ? markdownToTxt(abstract) : undefined
const metaDescription = rawAbstract ? rawAbstract?.split('\n')?.[0] : undefined

const levelLabels: Record<string, { label: string; color: string }> = {
    BEGINNER: { label: 'Débutant', color: 'bg-green-100 text-green-700' },
    INTERMEDIATE: { label: 'Intermédiaire', color: 'bg-yellow-100 text-yellow-700' },
    ADVANCED: { label: 'Avancé', color: 'bg-red-100 text-red-700' },
}

const levelInfo = level ? levelLabels[level] || { label: level, color: 'bg-gray-100 text-gray-700' } : null
---

<Layout
    title={`${title} – ${speakers.map((s) => s.name).join(', ')}`}
    description={metaDescription}
    metaImage={teaserImageUrl}>
    <!-- Hero Section -->
    <section class="relative overflow-hidden hero-gradient py-24 sm:py-32">
        <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
            <div class="absolute -top-40 -right-40 w-80 h-80 bg-secondary-500/10 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-primary-500/10 rounded-full blur-3xl"></div>
        </div>

        <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="scroll-animate">
                <!-- Back link -->
                <a
                    href={parentUrl}
                    class="inline-flex items-center text-white/70 hover:text-white transition-colors mb-8 text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Retour au programme
                </a>

                <!-- Badges -->
                <div class="flex flex-wrap gap-2 mb-6">
                    {
                        category && (
                            <span
                                class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold"
                                style={
                                    category.color
                                        ? `background-color: ${category.colorSecondary || category.color + '40'}; color: white`
                                        : 'background: rgba(255,255,255,0.2); color: white'
                                }>
                                {category.name}
                            </span>
                        )
                    }
                    {
                        levelInfo && (
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-white/20 text-white">
                                {levelInfo.label}
                            </span>
                        )
                    }
                </div>

                <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-6 leading-tight">
                    {title}
                </h1>

                <!-- Session info -->
                <div class="flex flex-wrap items-center gap-4 sm:gap-6 text-white/80 text-sm">
                    {
                        dateStart && (
                            <div class="flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                    />
                                </svg>
                                <span class="capitalize">
                                    {new Date(dateStart).toLocaleDateString('fr', {
                                        weekday: 'long',
                                        day: 'numeric',
                                        month: 'long',
                                    })}
                                </span>
                            </div>
                        )
                    }
                    {
                        dateStart && (
                            <div class="flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                    />
                                </svg>
                                <span>
                                    {new Date(dateStart).toLocaleTimeString('fr', {
                                        hour: '2-digit',
                                        minute: '2-digit',
                                    })}
                                    {dateEnd &&
                                        ` — ${new Date(dateEnd).toLocaleTimeString('fr', { hour: '2-digit', minute: '2-digit' })}`}
                                    ({durationMinutes} min)
                                </span>
                            </div>
                        )
                    }
                    {
                        track && !hideTrackTitle && (
                            <div class="flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                    />
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                    />
                                </svg>
                                <span>Salle : {track.name}</span>
                            </div>
                        )
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Content -->
    <section class="relative z-10 -mt-8">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
                <!-- Speakers -->
                {
                    speakers && speakers.length > 0 && (
                        <div class="px-6 sm:px-8 py-6 border-b border-gray-100">
                            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">
                                {speakers.length > 1 ? 'Speakers' : 'Speaker'}
                            </h2>
                            <div class="flex flex-col sm:flex-row gap-4">
                                {speakers.map((speaker) => (
                                    <a
                                        href={`/speakers/${speaker.id}`}
                                        class="flex items-center gap-4 group flex-1 p-3 rounded-xl hover:bg-gray-50 transition-colors duration-200">
                                        {speaker.photoUrl ? (
                                            <img
                                                class="w-14 h-14 rounded-full object-cover flex-shrink-0 group-hover:scale-105 transition-transform duration-200"
                                                src={speaker.photoUrl}
                                                alt={speaker.name}
                                                width="56"
                                                height="56"
                                                loading="lazy"
                                                decoding="async"
                                                onerror="this.onerror=null;this.src='/favicon-96x96.png'"
                                            />
                                        ) : (
                                            <img
                                                class="w-14 h-14 rounded-full object-cover flex-shrink-0 group-hover:scale-105 transition-transform duration-200"
                                                src="/favicon-96x96.png"
                                                alt={speaker.name}
                                                width="56"
                                                height="56"
                                                loading="lazy"
                                                decoding="async"
                                            />
                                        )}
                                        <div class="min-w-0">
                                            <div class="text-base font-semibold text-gray-900 group-hover:text-primary-600 transition-colors duration-200">
                                                {speaker.name}
                                            </div>
                                            {speaker.company && (
                                                <div class="text-sm text-gray-500 truncate">{speaker.company}</div>
                                            )}
                                        </div>
                                    </a>
                                ))}
                            </div>
                        </div>
                    )
                }

                <!-- Abstract -->
                {
                    abstract && (
                        <div class="px-6 sm:px-8 py-8">
                            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">
                                Description
                            </h2>
                            <div class="prose prose-lg max-w-none text-gray-700">
                                <MarkdownWrapper>
                                    <Markdown of={abstract} />
                                </MarkdownWrapper>
                            </div>
                        </div>
                    )
                }
            </div>
        </div>
    </section>

    <!-- Back to schedule -->
    <section class="py-12 bg-gradient-to-br from-gray-50 to-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <div class="scroll-animate">
                <a href={parentUrl} class="btn btn-primary text-lg px-8 py-4 hover-lift group">
                    <span class="mr-2 group-hover:animate-bounce-gentle">📅</span>
                    Retour au programme
                </a>
            </div>
        </div>
    </section>
</Layout>

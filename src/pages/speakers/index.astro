---
import Layout from '../../layouts/Layout.astro'
import CTASection from '../../components/cta/CTASection.astro'
import { EVENT_DATA } from '../../config'
import { getScheduleData } from '../../data/conference-hall'

const { speakers } = getScheduleData()
---

<Layout title="Nos Speakers" description="Découvrez les speakers qui vont animer Tech'Work Lyon 2026">
    <!-- Hero Section Immersif -->
    <section class="relative h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden hero-gradient">
        <!-- Background Gradient -->
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-br from-primary-800 via-secondary-800 to-primary-900"></div>
            <!-- Pattern décoratif -->
            <div
                class="absolute inset-0 opacity-10"
                style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;">
            </div>
        </div>

        <!-- Content -->
        <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <div class="scroll-animate">
                <div
                    class="inline-flex items-center px-4 py-2 bg-white/20 backdrop-blur-sm border border-white/20 text-white rounded-full text-sm font-semibold mb-6">
                    <span class="mr-2 animate-bounce-gentle">🎤</span>
                    Speakers · {EVENT_DATA.event.shortName}
                    {EVENT_DATA.event.year}
                </div>
                <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-6">
                    Les <span class="text-gradient">Alpacas</span> de la Scène
                </h1>
                <p class="text-lg sm:text-xl text-gray-200 max-w-3xl mx-auto">
                    Des experts et expertes qui ne crachent pas que de la laine : du concret, du vécu, et des retours
                    d'XP qui font vraiment avancer ton projet.
                </p>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 z-10">
            <div class="animate-bounce">
                <svg class="w-5 h-5 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"
                    ></path>
                </svg>
            </div>
        </div>
    </section>

    <!-- Section transition -->
    <!-- Speakers Section -->
    <section class="relative z-10 -mt-10 bg-white rounded-t-3xl py-16 sm:py-20 lg:py-24">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            {
                speakers.length === 0 ? (
                    <div class="text-center space-y-8 scroll-animate-scale">
                        <div class="bg-gradient-to-br from-primary-50 to-secondary-50 rounded-3xl p-8 sm:p-12 border border-primary-100 max-w-4xl mx-auto">
                            <div class="text-6xl mb-6">🦙</div>
                            <h2 class="text-2xl sm:text-3xl font-black text-gray-900 mb-6">
                                Nos experts affûtent leurs sabots !
                            </h2>
                            <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                                {EVENT_DATA.event.shortName} réunit les meilleures expertes et experts de la tech
                                lyonnaise et au-delà. Restez connecté·e·s pour découvrir bientôt notre sélection
                                d'alpacas de la scène.
                            </p>

                            <div class="grid md:grid-cols-2 gap-6 mb-8">
                                <div class="bg-white rounded-xl p-6 border border-gray-200 hover-lift">
                                    <div class="text-3xl mb-3">🚀</div>
                                    <h3 class="font-bold text-gray-900 mb-2">Expertise technique</h3>
                                    <p class="text-sm text-gray-600">
                                        Des talks pointus sur les dernières technologies — pas du baratin, du concret
                                    </p>
                                </div>
                                <div class="bg-white rounded-xl p-6 border border-gray-200 hover-lift">
                                    <div class="text-3xl mb-3">💡</div>
                                    <h3 class="font-bold text-gray-900 mb-2">Retours d'XP</h3>
                                    <p class="text-sm text-gray-600">
                                        Des histoires vraies de projets, sans tondre la réalité
                                    </p>
                                </div>
                                <div class="bg-white rounded-xl p-6 border border-gray-200 hover-lift">
                                    <div class="text-3xl mb-3">🌟</div>
                                    <h3 class="font-bold text-gray-900 mb-2">Diversité</h3>
                                    <p class="text-sm text-gray-600">
                                        Une programmation inclusive, comme un troupeau bien équilibré
                                    </p>
                                </div>
                                <div class="bg-white rounded-xl p-6 border border-gray-200 hover-lift">
                                    <div class="text-3xl mb-3">🎤</div>
                                    <h3 class="font-bold text-gray-900 mb-2">Formats innovants</h3>
                                    <p class="text-sm text-gray-600">
                                        Talks, workshops et sessions interactives — zéro monologue soporifique
                                    </p>
                                </div>
                            </div>

                            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                                <a
                                    href="/cfp"
                                    class="btn btn-primary text-lg px-8 py-4 hover-lift group"
                                    aria-label="Proposer un talk (ouvrir la page CFP)"
                                    data-cta
                                    data-placement="speakers-empty-cfp">
                                    <span class="mr-2 group-hover:animate-bounce-gentle" aria-hidden="true">
                                        📝
                                    </span>
                                    Proposer un talk
                                </a>
                                <a href="/team" class="btn btn-ghost text-lg px-8 py-4 hover-lift group">
                                    <span class="mr-2 group-hover:animate-bounce-gentle" aria-hidden="true">
                                        👥
                                    </span>
                                    Contacter l'équipe
                                </a>
                            </div>
                        </div>
                    </div>
                ) : (
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 stagger-children">
                        {speakers.map((speaker, index) => (
                            <a
                                href={`/speakers/${speaker.id}`}
                                class="speaker-card group block"
                                style={`animation-delay: ${index * 0.1}s`}>
                                <div class="bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-primary-300 transition-all duration-300 hover-lift scroll-animate-scale h-full">
                                    <div class="text-center flex flex-col items-center h-full">
                                        <div class="relative mb-4">
                                            <img
                                                class="w-20 h-20 rounded-full mx-auto object-cover group-hover:scale-110 transition-transform duration-300"
                                                src={speaker.photoUrl || '/favicon-96x96.png'}
                                                alt={speaker.name}
                                                width="80"
                                                height="80"
                                                loading="lazy"
                                                decoding="async"
                                                onerror="this.onerror=null;this.src='/favicon-96x96.png'"
                                            />
                                        </div>
                                        <h3 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-primary-600 transition-colors duration-300">
                                            {speaker.name}
                                        </h3>
                                        <p class="text-sm text-gray-600 line-clamp-1">
                                            {speaker.company
                                                ? speaker.jobTitle
                                                    ? `${speaker.jobTitle} • ${speaker.company}`
                                                    : speaker.company
                                                : '\u00A0'}
                                        </p>
                                    </div>
                                </div>
                            </a>
                        ))}
                    </div>
                )
            }
        </div>
    </section>

    <!-- Call for Papers Info -->
    <section class="py-12 sm:py-16 lg:py-20 bg-gradient-to-br from-gray-50 to-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-2 gap-8 lg:gap-12 items-center">
                <!-- Info Content -->
                <div class="scroll-animate-left">
                    <h2 class="text-2xl sm:text-3xl font-black text-gray-900 mb-6">
                        Vous avez une expertise à partager ?
                    </h2>

                    <div class="space-y-6">
                        <div class="flex items-start space-x-4">
                            <div
                                class="w-12 h-12 bg-primary-100 text-primary-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                <span class="text-xl">🎯</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 mb-2">Audience passionnée</h3>
                                <p class="text-gray-600">
                                    Partagez votre expertise avec des développeurs motivés et curieux sur leur temps de
                                    travail.
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start space-x-4">
                            <div
                                class="w-12 h-12 bg-secondary-100 text-secondary-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                <span class="text-xl">📈</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 mb-2">Visibilité</h3>
                                <p class="text-gray-600">
                                    Augmentez votre notoriété dans l'écosystème tech lyonnais et au-delà.
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start space-x-4">
                            <div
                                class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                <span class="text-xl">🤝</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 mb-2">Networking</h3>
                                <p class="text-gray-600">
                                    Rencontrez d'autres expertes, experts et créez des liens durables dans la
                                    communauté.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CFP Card -->
                <div class="scroll-animate-right">
                    <div
                        class="bg-gradient-to-br from-primary-50 to-secondary-50 rounded-2xl p-8 border border-primary-100 hover-lift">
                        <div class="text-center">
                            <div class="text-5xl mb-4">🦙</div>
                            <h3 class="text-xl font-bold text-gray-900 mb-4">Rejoins l'aventure !</h3>
                            <p class="text-gray-600 mb-6 leading-relaxed">
                                Les candidatures sont ouvertes ! Propose ton talk et deviens un alpaca de la scène
                                Tech'Work.
                            </p>
                            <div class="space-y-3">
                                <a href="/cfp" class="btn btn-primary w-full hover-lift group">
                                    <span class="mr-2 group-hover:animate-bounce-gentle">📝</span>
                                    Proposer un talk
                                </a>
                                <p class="text-xs text-gray-500">
                                    Sélection sur dossier • Accompagnement personnalisé • Ola supervise 🦙
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <CTASection
        title="Prêt·e à rejoindre la communauté ?"
        description="Réserve ta place et viens découvrir nos alpacas de la scène en live. Talks, workshops, networking — tout ça sur ton temps de travail."
        placement="content-speakers"
    />
</Layout>
